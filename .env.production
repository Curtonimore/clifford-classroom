# Environment variables for Clifford Classroom
# FOR VERCEL DEPLOYMENT REFERENCE
# Upload these values to your Vercel project settings

# Placeholder values for build process
# These will be overwritten by actual values in Vercel's Environment Variables

# MongoDB Connection
MONGODB_URI=mongodb+srv://build:build@buildcluster.mongodb.net/build

# Next Auth - CRITICAL: This must be your Vercel URL, not localhost
NEXTAUTH_URL=https://clifford-classroom.vercel.app
NEXTAUTH_SECRET=build-placeholder-secret-safe-for-commit

# Google Provider
GOOGLE_CLIENT_ID=build-placeholder-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=build-placeholder-secret

# Admin users
ADMIN_EMAILS=admin@example.com

# Claude API
ANTHROPIC_API_KEY=sk-ant-build00000000000000000000000000
USE_CLAUDE_API=true

# OpenAI API (Not currently used)
OPENAI_API_KEY=

# Stripe Configuration
# Replace these with actual values from your Stripe dashboard once you set it up
STRIPE_SECRET_KEY=sk_test_build0000000000000000000000000000000000000
STRIPE_PUBLISHABLE_KEY=pk_test_build0000000000000000000000000000000000000
STRIPE_WEBHOOK_SECRET=whsec_build0000000000000000000000000000000000000
STRIPE_PRICE_BASIC=price_build000000000000
STRIPE_PRICE_PREMIUM=price_build000000000000 